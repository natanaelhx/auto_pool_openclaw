{
  "name": "auto-pool-openclaw",
  "version": "0.8.0",
  "description": "Skill OpenClaw para analisar pools DeFi EVM/Solana com autonomia simulada, signer via env, pools, swap, bridge, wallet, watcher e auditoria.",
  "author": "NatanaelH",
  "license": "Proprietary",
  "homepage": "https://github.com/natanaelhx/auto_pool_openclaw",
  "min_openclaw_version": "2026.4.0",
  "runtime": "openclaw",
  "entry": ".",
  "permissions": {
    "allow": [
      "group:fs",
      "group:network"
    ],
    "elevated": [],
    "deny": []
  },
  "dependencies": {
    "bins": [
      "python3"
    ],
    "env": [
      "COINGECKO_API_KEY",
      "DEFILLAMA_API_KEY",
      "DUNE_API_KEY",
      "AUTO_POOLS_WALLET_ADDRESS",
      "AUTO_POOLS_DEFAULT_PROFILE",
      "AUTO_POOLS_USE_SAMPLE",
      "AUTO_POOLS_EXECUTION_ENABLE",
      "AUTO_POOLS_SIGNER_REF",
      "AUTO_POOLS_PRIVATE_KEY",
      "AUTO_POOLS_EVM_PRIVATE_KEY",
      "EVM_PRIVATE_KEY",
      "AUTO_POOLS_ALLOW_PRIVATE_KEY_SIGNER",
      "AUTO_POOLS_AUTONOMY_ENABLE",
      "AUTO_POOLS_OPEN_IF_CLEAR",
      "AUTO_POOLS_CAPITAL_USD",
      "AUTO_POOLS_ALLOCATION_PCT",
      "AUTO_POOLS_LIMIT",
      "AUTO_POOLS_CHAIN",
      "AUTO_POOLS_MARKET_DATA",
      "AUTO_POOLS_MIN_SCORE",
      "AUTO_POOLS_MAX_OPEN_POSITIONS",
      "AUTO_POOLS_DAILY_BUDGET_USD"
    ]
  },
  "pricing_tier": "free",
  "tags": [
    "defi",
    "trading",
    "yield",
    "pools",
    "portfolio",
    "risk"
  ]
}
