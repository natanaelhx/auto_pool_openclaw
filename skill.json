{
  "name": "auto-pool-openclaw",
  "version": "0.1.0",
  "description": "Skill OpenClaw para analisar, ranquear, simular e planejar automacao segura de pools DeFi EVM/Solana.",
  "author": "NatanaelH",
  "license": "Proprietary",
  "homepage": "https://github.com/natanaelhx/auto_pool_openclaw",
  "min_openclaw_version": "2026.4.0",
  "runtime": "openclaw",
  "entry": ".",
  "permissions": {
    "allow": [
      "group:fs",
      "group:network"
    ],
    "elevated": [],
    "deny": []
  },
  "dependencies": {
    "bins": [
      "python3"
    ],
    "env": [
      "COINGECKO_API_KEY",
      "DEFILLAMA_API_KEY",
      "DUNE_API_KEY",
      "AUTO_POOLS_WALLET_ADDRESS",
      "AUTO_POOLS_DEFAULT_PROFILE",
      "AUTO_POOLS_USE_SAMPLE",
      "AUTO_POOLS_EXECUTION_ENABLE",
      "AUTO_POOLS_SIGNER_REF"
    ]
  },
  "pricing_tier": "free",
  "tags": [
    "defi",
    "trading",
    "yield",
    "pools",
    "portfolio",
    "risk"
  ]
}
